{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vpnmgr",
  "version": "0.1.0",
  "identifier": "com.vpnmgr.desktop",
  "build": {
    "frontendDist": "./dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "resources": {
      "../../app/static": "static",
      "runtime": "runtime",
      "bundled-images": "images"
    },
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0"
    }
  }
}
